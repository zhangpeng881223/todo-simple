[Unit]
Description=XiaoU Todo telemetry relay
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/xiaou-telemetry
EnvironmentFile=/etc/xiaou-telemetry.env
ExecStart=/usr/bin/python3 /opt/xiaou-telemetry/telemetry_server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
